{
  "name": "saude-memora-frontend",
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "framework": "create-react-app",
  "env": {
    "REACT_APP_API_URL": "https://saude-memora.onrender.com"
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://saude-memora.onrender.com/api/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
